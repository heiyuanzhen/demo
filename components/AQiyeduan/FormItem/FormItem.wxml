<view class="form-item" wx:if="{{type == 'text'}}" style="{{styleStr}}">
  <view class="form-title">
    <view class="form-text">{{label}}</view>

    <view class="form-require" wx:if="{{isRequire}}">*</view>
  </view>
  <view class="form-inp">
    <input type="text" class="in-p" value="{{value}}" placeholder="{{placeholder}}" bindinput="InputTextChange" data-key="{{key}}" placeholder-class="place-class" />
  </view>
</view>

<block wx:if="{{type == 'select'}}">
  <!--一级-->
  <view class="form-item" wx:if="{{level == 'one'}}" style="{{styleStr}}">
    <view class="form-title">
      <view class="form-text">{{label}}</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp">
      <picker range="{{normalRangeArr}}" range-key="name" data-key="{{key}}" value="{{index}}" bindchange="pickerChange">
        <view class="picker place-class_on" wx:if="{{normalRangeArr[index].name}}">
          {{normalRangeArr[index].name}}
        </view>
        <view class="picker place-class" wx:else>
          {{placeholder}}
        </view>
      </picker>
      <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" />
    </view>
  </view>
  <!--二级-->
  <view class="form-item" wx:if="{{level == 'two'}}" style="{{styleStr}}">
    <view class="form-title">
      <view class="form-text">{{label}}</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp">
      <picker range="{{normalRangeArr}}" range-key="name" value="{{index}}" bindchange="pickerChange">
        <view class="picker place-class">
          {{normalRangeArr[index].name || placeholder }}
        </view>
      </picker>
      <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" />
    </view>
  </view>
  <!--三级-->
  <view class="form-item" wx:if="{{level == 'three'}}" style="{{styleStr}}">
    <view class="form-title">
      <view class="form-text">{{label}}</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp">
      <picker mode="multiSelector" range="{{threelevel}}" value="{{index}}" bindchange="threeLevelPickerChange" bindcolumnchange="bindMultiPickerColumnChange">
        <view class="picker place-class place-class_on" wx:if="{{selectText[0] || selectText[1] || selectText[2] }}">
          {{ selectText[0] }} {{ selectText[1] == '不限' ? '' : selectText[1] }} {{ selectText[2] == '不限' ? '' : selectText[2] }}
        </view>
        <view class="picker place-class" wx:else>
          {{ placeholder }}
        </view>
      </picker>
      <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" />
    </view>
  </view>
</block>

<view class="form-item" wx:if="{{type == 'textarea'}}">
  <view class="form-title">
    <view class="form-text">{{label}}</view>
    <view class="form-require">*</view>
  </view>
  <!-- <view class="form-area"> -->
  <!-- <textarea
		 type="text"
		 class="in-a"
		 placeholder="{{placeholder}}"
		 placeholder-class="place-class"
		 bindinput="InputTextChange"
		 data-key="{{key}}"
		 value="{{value}}"
		/> -->

  <z-Eeditor value="{{value}}" isEdit="{{true}}" isScroll="{{true}}" bind:editorChange="editorChange" isUploadImage="{{false}}" data-key="{{key}}" isPagetop="{{true}}" bind:pagetop="pagetop" width="670rpx"></z-Eeditor>

  <!-- </view> -->
</view>

<block wx:if="{{type == 'address' && isboss==2}}">
  <view class="form-item" style="width: 670rpx;">
    <view class="form-title" style="{{fw?'margin-bottom: 20rpx;':''}}">
      <view class="form-text" style="{{fw?'font-weight:bold;':''}}">工作地址</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp">
      <picker mode="region" bindchange="bindRegionChange" value="{{region}}" custom-item="{{customItem}}">
        <view class="place-class_on" wx:if="{{region.length > 0}}">
          当前选择：{{region[0]}} {{region[1] == '不限' ? '' : region[1]}} {{region[2] == '不限' ? '' : region[2]}}
        </view>
        <view class="place-class" wx:else>
          请选择城市
        </view>
      </picker>
      <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" />
    </view>
  </view>
</block>
<block wx:if="{{type == 'addressTwo' && isboss==1}}">
  <view class="form-item" style="width: 670rpx;">
    <view class="form-title" style="{{fw?'margin-bottom: 20rpx;':''}}">
      <view class="form-text" style="{{fw?'font-weight:bold;':''}}">工作地址</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp">
      <picker mode="region" bindchange="bindRegionChange" value="{{region}}" custom-item="{{customItem}}">
        <view class="place-class_on" wx:if="{{region && region.length > 0}}">
          当前选择：{{region[0]}} {{region[1] == '不限' ? '' : region[1]}} {{region[2] == '不限' ? '' : region[2]}}
        </view>
        <view class="place-class" wx:else>
          请选择城市
        </view>
      </picker>
      <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" />
    </view>
  </view>
</block>

<view class="form-item_edit" wx:if="{{type == 'edit-text'}}" style="{{styleStr}}">
  <view class="form-title_edit">
    <view>{{label}}</view>
    <view class="form-require" wx:if="{{isRequire}}">*</view>
  </view>
  <view class="form-inp_edit">
    <input type="text" class="in-p" value="{{value}}" placeholder="{{placeholder}}" bindinput="InputTextChange" data-key="{{key}}" placeholder-class="place-class" style="flex: 1" />
    <view class="dark-text_eee" style="margin-right: 20rpx">
      {{textRight}}
    </view>
  </view>
</view>

