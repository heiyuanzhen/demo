          请选择城市
        </view>
      </picker>
      <!-- <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" /> -->
    </view>
  </view>
</block>

<block wx:if="{{type == 'edit-birthday'}}">
  <view class="form-item_edit" style="width: 670rpx;">
    <view class="form-title_edit">
      <view>出生日期</view>
      <view class="form-require">*</view>
    </view>
    <view class="form-inp_edit">
      <picker mode="date" value="{{birthday}}" start="1950-01-01" end="2022-12-24" bindchange="dateChange">
        <view class="place-class">
          {{birthday || '请选择您的生日'}}
        </view>
      </picker>
      <!-- <image src="https://cdn1.chinayarn.com/dsc/2020-10/img/Tl2mcphpJoz7kj1603159781201020.png" class="in-icon" /> -->
    </view>
  </view>
</block>

<block wx:if="{{type == 'edit-salary'}}">
  <view class="form-item_edit" style="{{styleStr}}">
    <view class="form-title_edit">
      <view>{{label}}</view>
      <view class="form-require" wx:if="{{isRequire}}">*</view>
    </view>
    <view class="form-inp_edit_salary">
      <input type="number" class="inp-salary" value="{{minsalary || ''}}" placeholder="请输入" bindinput="InputTextChange" data-key="minsalary" placeholder-class="place-class" />
      <view style="padding: 0 30rpx;" class="dark-text_eee">至</view>
      <input type="number" class="inp-salary" value="{{maxsalary || ''}}" placeholder="请输入" bindinput="InputTextChange" data-key="maxsalary" placeholder-class="place-class" />
      <view class="dark-text_eee">
        元/月
      </view>
    </view>
  </view>
</block>

