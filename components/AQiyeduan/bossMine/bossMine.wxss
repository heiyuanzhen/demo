page{
  background-color: #f2f2f2;
}
.user-info{
  background-color: #26BA8D;
  width: 100%;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.userinfo-top{
  display: flex;
  padding: 30rpx;
  box-sizing: border-box;
  justify-content: space-between;
  align-items: center;
}
.userinfo-avatar .image{
  width: 100%;
  height: 100%;
}
.userinfo-avatar{
  border-radius: 50%;
  width: 90rpx;
  height: 90rpx;
  overflow: hidden;
  margin-left: 20rpx;
}
.userinfo-name{
  color: #FFFFFF;
  flex: 1;
  margin-left: 35rpx;
}
.pleaseLogin{
  background-color: transparent;
  color: #ffffff;
  text-align: left;
}
.pleaseLogin::after{
  border: none;
}
.com-name{
  font-size: 34rpx;
  font-weight: bold;
}
.com-btn{
  margin-top: 10rpx;
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
}
.userinfo-edit .image{
  width: 33rpx;
  height: 35rpx;
}
.userinfo-edit{
  height: 100%;
  color: #fff;
  font-size: 24rpx;
  margin-top: 20rpx;
  display: flex;
  color: rgba(255, 255, 255, 0.8);
}
.userinfo-bottom {
  /* text-align: center; */
  display: flex;
  align-items: flex-end;
}
.userinfo-bottom .image{
  width: 730rpx;
  height: 86rpx;
  border-radius: 20rpx 20rpx 0 0;
  margin: 0 auto;
  margin-left: 10rpx;
}

.talent-dark {
  margin-left: 15px;
  height: 2rpx;
  background-color: #ececec;
}
.dark-eee{
  height: 15rpx;
  background-color: rgba(246, 246, 246, 1);
  width: 100%;
}

.scrollView{
  width: 750rpx;
  padding-bottom: 150rpx;
}

.col-item{
  padding: 35rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  border-bottom: 2rpx solid #ececec;
}
.col-item:last-child{
  border-bottom: 2rpx solid transparent;
}
.col-title{
  font-size: 32rpx;
  font-weight: bold;
  color: #444444;
}
.col-right{
  display: flex;
  justify-content: center;
  align-items: center;
}
.rig-text{
  font-size: 28rpx;
  color: #abadbf;
  margin-right: 25rpx;
}
.rig-img{
  width: 10rpx;
  height: 18rpx;
}

.bg-color{
  /* background-color: rgba(246, 246, 246, 1); */
}

.logout-con{
  width: 100%;
  margin-top: 150rpx;
  text-align: center;
}
.logout-btn{
  width: 60%;
  background-color: transparent;
  color: rgba(168,173,191, 0.8);
  border-radius: 100rpx;
  border: 2rpx solid rgba(168,173,191, 0.6);
  margin: 0 auto;
  font-size: 28rpx;
}

.company-n{
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 14rpx;
}