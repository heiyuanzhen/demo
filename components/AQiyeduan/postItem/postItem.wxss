.post-item{
  overflow: hidden;
  padding: 30rpx 40rpx;
}
.item-top{
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 34rpx;
  font-weight: bold;
}
.post-name{
  color: #444444;
  display: -webkit-box;
  text-overflow: ellipsis;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  width: 60%;
}
.post-gz{
  color: #26BA8D;
  display: -webkit-box;
  text-overflow: ellipsis;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
.item-center{
  display: flex;
  justify-content: flex-start;
  margin-top: 15rpx;
  font-size: 24rpx;
}
.fl-item{
  background-color: #eeeeee; 
  color: #444444;
  height: 46rpx;
  line-height: 46rpx;
  text-align: center;
  margin-left: 20rpx;
  padding: 2rpx 15rpx;
}
.fl-item:nth-child(1){
  margin-left: 0;
}
.item-bottom{
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #abadbf;
  margin-top: 15rpx;
}


.btn-group{
  display: flex;
  align-items: center;
}
.btn-cls{
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  padding: 0 40rpx;
  border: 2rpx solid #abadbf;
  color: #abadbf;
  font-size: 28rpx;
  border-radius: 24rpx;
}
.btn-cls:nth-child(2){
  margin-left: 30rpx;
}

.isstop{
  color: #A8ADBF !important;
}

.db-sj{
  display: -webkit-box;
  text-overflow: ellipsis;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  width: 35%; /** 限制地址显示字数 **/
}