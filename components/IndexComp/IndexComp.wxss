
.header-top{
  background-color: #F6F6F6;
  width: 100%;
  height: 150rpx;
  padding: 10rpx 40rpx;
  box-sizing: border-box;
}
.header-top .text{
  color: #fff;
  font-size: 46rpx;
}
.hedaer-search{
  width: 100%;
  background-color: #fff;
  border-radius: 5rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  box-sizing: border-box;
  padding: 20rpx 40rpx;
  margin-top: 20rpx;
}
.search-icon{
  width: 35rpx;
  height: 35rpx;
}
.close-icon{
  width: 30rpx;
  height: 30rpx;
  padding-left: 30rpx;
}
.search-inp{
  flex: 1;
  margin-left: 20rpx;
}


