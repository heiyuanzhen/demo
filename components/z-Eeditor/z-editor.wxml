<import src="../wxParse/wxParse.wxml" />
<!-- 回显 -->
<!-- <z-editor bind:editorChange="editorChange" editorHeight="300" value="{{form.introduce}}"></z-editor>
  1. 传值事件 editorChange
      editorIpt(e) ==> 传递给父组件
      editorIpt: function (e) {
        console.log(e, 'eee2');
        this.triggerEvent('editorChange', e)
      },
  2. 富文本高度  editorHeight Number
      多出会自动滚动
      editorHeight 值
      1. auto String  auto 自动全铺开
      2. 300  Number  按数字显示 数字
      3. 没传 默认值 高300px显示
  3. value （默认值）  String
  4. isEdit (可否编辑) Boolean -->
<view class="editor" style="width: {{width}}">
	<view class="toolbar" catchtouchend="format" wx:if="{{isEdit && isToolbar}}">
		<i wx:if="{{isUploadImage}}" class="iconfont icon-charutupian" catchtouchend="insertImage"></i>
		<i class="iconfont icon-format-header-2 {{formats.header === 2 ? 'ql-active' : ''}}" data-name="header"
			data-value="{{2}}"></i>
		<i class="iconfont icon-format-header-3 {{formats.header === 3 ? 'ql-active' : ''}}" data-name="header"
			data-value="{{3}}"></i>
		<i class="iconfont icon-zitijiacu {{formats.bold ? 'ql-active' : ''}}" data-name="bold"></i>
		<i class="iconfont icon-zitixieti {{formats.italic ? 'ql-active' : ''}}" data-name="italic"></i>
		<i class="iconfont icon-zitixiahuaxian {{formats.underline ? 'ql-active' : ''}}" data-name="underline"></i>
		<i class="iconfont icon--checklist" data-name="list" data-value="check"></i>
		<i class="iconfont icon-youxupailie {{formats.list === 'ordered' ? 'ql-active' : ''}}" data-name="list"
			data-value="ordered"></i>
		<i class="iconfont icon-wuxupailie {{formats.list === 'bullet' ? 'ql-active' : ''}}" data-name="list"
			data-value="bullet"></i>
	</view>
	<!-- {{editorHeight + 'editorHeight'}} -->
	<!-- <view class="container1" style="height:{{ editorHeight == 0 ? 'auto' : (editorHeight + 'px')}};padding: 20rpx 0;">
		<editor id="{{editorid}}" style="height: auto;" read-only="{{!isEdit}}" class="ql-container"
			catch:touchmove="touchmove" placeholder="{{placeholder}}" bindstatuschange="onStatusChange"
			bindready="onEditorReady" />
	</view> -->
	<view class="container1" style="height:{{ editorHeight == 0 ? 'auto' : (editorHeight + 'px')}};padding: 20rpx 0;" >
		<editor
	   id="editorid"
		 style="height: auto;"
		 read-only="{{!isEdit}}"
		 class="ql-container"
		 catch:touchmove="touchmove"
		 placeholder="{{placeholder}}"
		 bindstatuschange="onStatusChange"
		 bindinput="editorIpt"
		 bindready="onEditorReady"
		 bindblur="onbindblur"
		 bindfocus="onbindfocus"
		/>
	</view>

	<!-- <view class="container" style="height:{{editorHeight}}px;">
  <editor id="{{editorid}}"  bindinput="editorIpt" class="ql-container" placeholder="{{placeholder}}" bindstatuschange="onStatusChange" bindready="onEditorReady">
  </editor>
</view> -->

</view>