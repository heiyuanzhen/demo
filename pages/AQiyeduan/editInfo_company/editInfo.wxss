page {
  background: #f1f4f6;
  width: 100%;
  height: 100%;
}

.form-container {
  width: 100%;
  background-color: #fff;
  padding: 32rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.form-item {
  width: 100%;
  padding: 40rpx 0;
  border-bottom: 2rpx solid #ececec;
}

.icon-text {
  color: #999999;
  display: flex;
  flex-direction: column;
}

.icon-img {
  position: relative;
  margin-right: 40rpx;
}

.icon-img image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 8rpx;
  overflow: hidden;
}



.form-label {
  font-size: 32rpx;
  color: #999999;
  display: flex;
  justify-content: space-between;
  width: 100%;
}

.form-value {
  color: #000;
  font-size: 32rpx;
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-value input {
  width: 85%;
}

.form-value image {
  width: 12rpx;
  height: 20rpx;
}

.form-item-lr {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-primary {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}


/* .classify{
  display: flex;
  flex-direction: column;
  align-items: flex-start;
} */

.form-item-classify {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 15rpx;
}

.classify-item {
  font-size: 26rpx;
  color: #999999;
  width: 150rpx;
  height: 60rpx;
  background-color: transparent;
  border: 1rpx solid #999999;
  text-align: center;
  margin-left: 20rpx;
  line-height: 60rpx;
}

.classify-item_on {
  background-color: #36CEB4;
  color: #fff;
  border: 1rpx solid #36CEB4;
}

.classify-item:nth-child(4n+1) {
  margin-left: 0;
}

.classify-item:nth-child(n+5) {
  margin-top: 15rpx;
}

.form-item textarea {
  height: 150rpx;
  margin-top: 20rpx;
}

.bottomsub {
  bottom: 0;
  padding: 10rpx 0 20rpx 0;
  margin-top: 20rpx;
  background-color: #fff;
  border-top: 2rpx solid #ececec;
  z-index: 10000;  
}

.icon-close {
  position: absolute;
  top: 0;
  right: 0;
  width: 32rpx;
  height: 32rpx;
  background-color: transparent;
  background-image: url('https://cdn1.chinayarn.com/dsc/2020-09/img/BFChFphp3UDVSx1599643144200909.png');
  background-size: 100% 100%;
}

.form-select {
  width: 100%;
}

.form-select image {
  transform: rotate(90deg);
  width: 13rpx;
  height: 20rpx;
  margin-right: 20rpx;
}

.select-body {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-body>view {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.my-class {
  width: 100%;
}

.getuser{
  position: relative;
  background-color: transparent;
}
.getuser::after{
  border: none;
  background-color: transparent;
}

.bottomsub{
  width: 100%;
  position: fixed;
  bottom: 0;
  padding: 10rpx 0;
  text-align: center;
}
.save-btn::after{
  border: none;
  background-color: transparent;
}
.save-btn{
  background-color: #26BA8D;
  color: #fff;
  border-radius: 75rpx;
  font-weight: normal;
  margin: 0 20rpx;
}
.save-btn:active{
  opacity: 0.8;
}
