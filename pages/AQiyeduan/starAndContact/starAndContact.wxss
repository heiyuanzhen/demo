page{
  background-color: #fff; 
}
.tab-list{
  display: flex;
  justify-content: space-around;
  border-bottom: 1rpx solid #ececec;
}
.tab-item{
  padding: 40rpx 0;
  border-bottom: 8rpx solid transparent;
  color: #6D7278;
}
.tab-item_on{
  border-bottom: 8rpx solid #26BA8D;
  color: #26BA8D;
  font-weight: bold;
}

.pleaseLogin{
  background-color: transparent;
  color: #fff;
  font-size: 35rpx;
  margin: 0;
  width: 180rpx;
}

.talent-list{
  padding-bottom: 120rpx;
  min-height: 60vh;
}

.nomore{
  width: 100%;
  height: 50rpx;
  background-color: transparent;
  padding: 20rpx 0;
  text-align: center;
  line-height: 50rpx;
  font-size: 24rpx;
  color: #999999;
}

.nomoredata{
  width: 100%;
  text-align: center;
  padding: 50rpx 0;
  color: #999999;
}

.talent-dark{
  background-color: #f2f2f2;
  height: 2rpx;
}