page{
  background-color: #f6f6f6;
}
.resume-list{
  padding-bottom: 90rpx;
}
.resume-item{
  display: flex;
  justify-content: space-between;
  padding: 35rpx 30rpx;
  align-items: center;
  background-color: #fff;
}
.resume-item + .resume-item{
  margin-top: 24rpx;
}
.r-left{
  width: 90rpx;
  height: 90rpx;
}
.l-icon{
  width: 100%;
  height: 100%;
}
.r-center{
  display: flex;
  flex: 1;
  flex-direction: column;
  justify-content: flex-start;
  margin-left: 30rpx;
  padding-right: 20rpx;
}
.c-top{
  font-size: 30rpx;
  color: #444444;
  display: -webkit-box;
  text-overflow: ellipsis;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
}
.c-bottom{
  font-size: 28rpx;
  color: #A8ADBF;
}
.r-icon{
  font-size: 30rpx;
  text-align: center;
  line-height: 5rpx;
  color: #A8ADBF;
  padding: 40rpx 0;
}
.r-icon image{
  width: 40rpx;
  height: 50rpx;
}

.upload-resume{
  background-color: #fff;
  width: 100%;
  position: fixed;
  bottom: 0;
  left: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 8rpx 0;
}
.upload-btn{
  width: 670rpx;
  height: 82rpx;
  background-color: #26BA8D;
  border-radius: 70rpx;
  color: #fff;
  font-size: 34rpx;
  text-align: center;
  line-height: 82rpx;
}

.nomore{
  width: 750rpx;
  text-align: center;
  color: #A8ADBF;
  font-size: 30rpx;
  padding: 30rpx 0;
}