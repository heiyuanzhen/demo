page{
  background-color: #fff;
}
.choose{
  width: 100%;
  margin-top: 88rpx;
  display: flex;
  justify-content: center;
  flex-direction: column;
  align-items: center;
}
.choose image{
  width: 100%;
  height: 100%;
}
.choose view + view {
  margin-top: 40rpx;
}

.ch-item{
  position: relative;
  background: #FFFFFF;
  border-radius: 12rpx;
  width: 690rpx;
  height: 400rpx;
  overflow: hidden;
}
.currentText{
  position: absolute;
  color: #999999;
  font-size: 22rpx;
  right: 108rpx;
  bottom: 140rpx;
}